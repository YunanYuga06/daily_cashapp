// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Disarankan untuk Vercel + Supabase
}

model User {
  email     String     @id @db.VarChar(255)
  name      String     @db.VarChar(255)
  password  String     @db.VarChar(255)
  image_url String?    @db.VarChar(255)
  token     String?    @db.VarChar(255)
  budgets   Budget[]
  reminders Reminder[]
  assets    Asset[]
  transactions Transaction[]

  @@map("users")
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(255)
  type        String   @db.VarChar(255) // 'income' or 'expense'
  description String?  @db.Text
  budgets     Budget[]
  transactions Transaction[]
}

model Asset {
  id             Int      @id @default(autoincrement())
  user           User     @relation(fields: [email_user], references: [email])
  email_user     String   @db.VarChar(255)
  asset_name     String   @db.VarChar(255)
  asset_type     String   @db.VarChar(255)
  first_amount   Int
  current_amount Int
  budgets        Budget[]
  transactions Transaction[]

  @@map("assets")
}

model Budget {
  id          Int      @id @default(autoincrement())
  email_user  String   @db.VarChar(255)
  id_category Int
  amount      Int
  first_period DateTime @db.Date
  last_period  DateTime @db.Date
  id_asset    Int?
  note        String? 

  user     User      @relation(fields: [email_user], references: [email])
  category Category  @relation(fields: [id_category], references: [id])
  asset    Asset?    @relation(fields: [id_asset], references: [id])
}

model Reminder {
  id          Int      @id @default(autoincrement())
  email_user  String   @db.VarChar(255)
  description String   @db.Text
  period      String
  date        DateTime @db.Date
  amount      Int      // Tambahkan baris ini
  user        User     @relation(fields: [email_user], references: [email])

  @@map("Reminder")
}

model Transaction {
  id          Int      @id @default(autoincrement())
  email_user  String   @db.VarChar(255)
  id_category Int
  id_asset    Int?     
  amount      Int      
  type        String   
  description String?  
  date        DateTime @db.Date 

  user     User     @relation(fields: [email_user], references: [email])
  category Category @relation(fields: [id_category], references: [id])
  asset    Asset?   @relation(fields: [id_asset], references: [id])

  @@map("transactions")
}